# .env — TEST FIXTURE. PLACEHOLDER VALUES ONLY. Not real secrets.
# Lives at .website-builder/.env (the documented fallback location per
# DESIGN-secrets-and-keys.md Layer 2 — "or .website-builder/.env per stack
# convention"). Used here instead of a project-root .env because the repo
# .gitignore ignores root-level .env files but whitelists tests/<captain>/fixture/
# .website-builder/** (Captain-0's Phase 5 gitignore exceptions). The resolver
# checks project-root .env first, then .website-builder/.env — this fixture
# exercises the fallback path, which is functionally identical for the resolver.
#
# Obviously-fake tokens so the test asserts the resolver returns THESE strings
# (mechanism check), not any real credential. See tests/README.md Phase 5.
WB_TEST_GEMINI_API_KEY=placeholder-gemini-not-a-real-key
WB_TEST_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder_publishable
# WB_TEST_PLAUSIBLE_KEY intentionally absent — it's required: false in keys.yaml,
# so the resolver must NOT flag it as unresolved.
