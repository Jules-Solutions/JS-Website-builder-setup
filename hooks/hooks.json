{
  "description": "website-builder plugin hooks — SessionStart detects entry mode + surfaces project state; PreToolUse gates anti-skip violations against the current phase's exit criteria. Handlers in Python at ${CLAUDE_PLUGIN_ROOT}/hooks-handlers/ per decision 59 + foundation/DESIGN-architecture.md.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks-handlers/session_start.py\" || python \"${CLAUDE_PLUGIN_ROOT}/hooks-handlers/session_start.py\" || py \"${CLAUDE_PLUGIN_ROOT}/hooks-handlers/session_start.py\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks-handlers/pre_tool_use.py\" || python \"${CLAUDE_PLUGIN_ROOT}/hooks-handlers/pre_tool_use.py\" || py \"${CLAUDE_PLUGIN_ROOT}/hooks-handlers/pre_tool_use.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
